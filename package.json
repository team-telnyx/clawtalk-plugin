{
  "name": "@clawtalk/plugin",
  "version": "0.1.0",
  "description": "Voice calls, SMS, missions, and approvals via ClawTalk — OpenClaw plugin",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "type": "module",
  "scripts": {
    "dev": "node --import @swc-node/register/esm-register src/index.ts",
    "build": "swc src -d build --strip-leading-paths",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "date-fns": "^4.1.0",
    "libphonenumber-js": "^1.12.26",
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@swc-node/register": "^1.11.1",
    "@swc/cli": "^0.7.8",
    "@swc/core": "^1.13.5",
    "@types/ws": "^8.5.13",
    "@types/node": "^24.3.1",
    "typescript": "~5.8.3"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "files": [
    "build",
    "openclaw.plugin.json",
    "skills"
  ],
  "license": "MIT"
}
